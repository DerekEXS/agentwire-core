FROM python:3.13-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# v2.0: a2a-sdk with server extras
COPY server_v2/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# v2.0.6: Patch a2a-sdk version_validator to accept v0.3 clients.
# The SDK rejects requests where A2A-Version major != expected major.
# v0.3 and v1.0 share the same JSON-RPC wire format, so we accept
# the cross-version request and respond with v1.0-compliant output.
RUN sed -i 's/return actual_v.major == expected_v.major/if actual_v.major == 0 and expected_v.major == 1: return True; return actual_v.major == expected_v.major/' \
    "$(python3 -c "import a2a.utils.version_validator; print(a2a.utils.version_validator.__file__)")"

# Both v1 (backup) and v2 (active) server code
COPY server/ /app/server/
COPY server_v2/ /app/server_v2/
COPY docker/core-config.yaml /app/server/config.yaml

RUN groupadd -r agentwire \
    && useradd -r -g agentwire -m -d /home/agentwire agentwire \
    && mkdir -p /data/history /data/peers \
    && chown -R agentwire:agentwire /app /data

USER agentwire

EXPOSE 18800

ENV CORE_LISTEN_HOST=0.0.0.0 \
    CORE_LISTEN_PORT=18800 \
    AGENTWIRE_HOME=/data \
    TASK_STORE_PATH=/data/tasks.db

VOLUME ["/data/history", "/data/peers"]

CMD ["python3", "-m", "server_v2.start", "--token-file", "/run/secrets/a2a-token.txt"]

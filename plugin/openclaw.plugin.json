{
  "id": "agentwire-a2a",
  "name": "AgentWire A2A Adapter",
  "description": "Exposes Google A2A v1.0 JSON-RPC endpoint for OpenClaw agents (v2.3)",
  "version": "2.3.0",
  "activation": { "onStartup": true },
  "contracts": { "tools": [] },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "authToken": {
        "type": "string",
        "description": "Bearer token required on /a2a/jsonrpc. Empty = loopback no-auth. Must match CORE peers.openclaw token when set.",
        "default": ""
      },
      "defaultAgent": { "type": "string", "default": "main" },
      "taskTimeoutSeconds": { "type": "integer", "default": 120 }
    }
  },
  "uiHints": {
    "authToken": { "label": "A2A Bearer Token", "sensitive": true },
    "defaultAgent": { "label": "Default Agent" }
  }
}
